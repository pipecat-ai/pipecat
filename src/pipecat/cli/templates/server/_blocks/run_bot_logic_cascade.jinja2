{# Main bot logic for cascade mode - uses indent_level variable passed from parent #}
{% if 'twilio_daily_sip_dialin' in transports %}
{% if enable_eval %}
{{ "# SIP call details (sip_uri, call_sid) arrive in the request body (eval runs have none)" | indent(indent_level, first=True) }}
{{ "request = (" | indent(indent_level, first=True) }}
{{ "AgentRequest.model_validate(runner_args.body)" | indent(indent_level + 4, first=True) }}
{{ "if not isinstance(runner_args, EvalRunnerArguments)" | indent(indent_level + 4, first=True) }}
{{ "else None" | indent(indent_level + 4, first=True) }}
{{ ")" | indent(indent_level, first=True) }}
{% else %}
{{ "# SIP call details (sip_uri, call_sid) arrive in the request body" | indent(indent_level, first=True) }}
{{ "request = AgentRequest.model_validate(runner_args.body)" | indent(indent_level, first=True) }}
{% endif %}

{% elif 'daily_pstn_dialout' in transports or 'twilio_daily_sip_dialout' in transports %}
{% if enable_eval %}
{{ "# Outbound call settings arrive in the request body (eval runs have none)" | indent(indent_level, first=True) }}
{{ "dialout_settings = (" | indent(indent_level, first=True) }}
{{ "AgentRequest.model_validate(runner_args.body).dialout_settings" | indent(indent_level + 4, first=True) }}
{{ "if not isinstance(runner_args, EvalRunnerArguments)" | indent(indent_level + 4, first=True) }}
{{ "else None" | indent(indent_level + 4, first=True) }}
{{ ")" | indent(indent_level, first=True) }}
{% else %}
{{ "# Outbound call settings arrive in the request body" | indent(indent_level, first=True) }}
{{ "dialout_settings = AgentRequest.model_validate(runner_args.body).dialout_settings" | indent(indent_level, first=True) }}
{% endif %}

{% endif %}
{{ "# Speech-to-Text service" | indent(indent_level, first=True) }}
{% if stt_service and stt_service in service_configs %}
{{ ("stt = " ~ service_configs[stt_service]) | indent(indent_level, first=True) }}
{% endif %}

{{ "# Text-to-Speech service" | indent(indent_level, first=True) }}
{% if tts_service and tts_service in service_configs %}
{{ ("tts = " ~ service_configs[tts_service]) | indent(indent_level, first=True) }}
{% endif %}

{{ "# LLM service" | indent(indent_level, first=True) }}
{% if llm_service and llm_service in service_configs %}
{{ ("llm = " ~ service_configs[llm_service]) | indent(indent_level, first=True) }}
{% endif %}

{% if video_service and video_service in service_configs %}
{{ "# Video service (avatar)" | indent(indent_level, first=True) }}
{{ ("video = " ~ service_configs[video_service]) | indent(indent_level, first=True) }}
{% endif %}

{{ helpers.setup_context(external_turn_detection) | indent(indent_level, first=True) }}

{{ helpers.setup_feature_processors(recording, transcription, bot_type) | indent(indent_level, first=True) }}

{{ "# Pipeline - assembled from reusable components" | indent(indent_level, first=True) }}
{{ pipeline.cascade_pipeline(bot_type, transcription, recording, video_service) | indent(indent_level, first=True) }}

{{ "worker = PipelineWorker(" | indent(indent_level, first=True) }}
{{ "pipeline," | indent(indent_level + 4, first=True) }}
{{ "params=PipelineParams(" | indent(indent_level + 4, first=True) }}
{{ "enable_metrics=True," | indent(indent_level + 8, first=True) }}
{{ "enable_usage_metrics=True," | indent(indent_level + 8, first=True) }}
{% if bot_type == 'telephony' %}
{{ "audio_in_sample_rate=8000," | indent(indent_level + 8, first=True) }}
{{ "audio_out_sample_rate=8000," | indent(indent_level + 8, first=True) }}
{% endif %}
{{ ")," | indent(indent_level + 4, first=True) }}
{% if bot_type == 'web' or enable_observability %}
{{ "observers=[" | indent(indent_level + 4, first=True) }}
{% if enable_observability %}
{{ "WhiskerObserver(pipeline)," | indent(indent_level + 8, first=True) }}
{% endif %}
{{ "]," | indent(indent_level + 4, first=True) }}
{% endif %}
{{ ")" | indent(indent_level, first=True) }}

{% if 'daily_pstn_dialout' in transports or 'twilio_daily_sip_dialout' in transports %}
{% if enable_eval %}
{{ "# Dial-out only applies to real calls; eval runs get minimal handlers below." | indent(indent_level, first=True) }}
{{ "if dialout_settings is not None:" | indent(indent_level, first=True) }}
{{ "# Initialize dialout manager" | indent(indent_level + 4, first=True) }}
{{ "dialout_manager = DialoutManager(transport, dialout_settings)" | indent(indent_level + 4, first=True) }}

{% else %}
{{ "# Initialize dialout manager" | indent(indent_level, first=True) }}
{{ "dialout_manager = DialoutManager(transport, dialout_settings)" | indent(indent_level, first=True) }}

{% endif %}
{% endif %}
{# Event handlers - use macros based on transport type. With evals enabled, the
   telephony-specific handlers only apply to real calls; eval runs get a minimal set. #}
{% if 'daily_pstn_dialin' in transports %}
{{ handlers.daily_pstn_dialin_handlers(recording) | indent(indent_level, first=True) }}
{% elif 'daily_pstn_dialout' in transports %}
{% if enable_eval %}
{{ handlers.daily_pstn_dialout_handlers(recording) | indent(indent_level + 4, first=True) }}
{{ "else:" | indent(indent_level, first=True) }}
{{ handlers.eval_handlers(recording) | indent(indent_level + 4, first=True) }}
{% else %}
{{ handlers.daily_pstn_dialout_handlers(recording) | indent(indent_level, first=True) }}
{% endif %}
{% elif 'twilio_daily_sip_dialin' in transports %}
{% if enable_eval %}
{{ "if request is not None:" | indent(indent_level, first=True) }}
{{ handlers.twilio_daily_sip_dialin_handlers(recording) | indent(indent_level + 4, first=True) }}
{{ "else:" | indent(indent_level, first=True) }}
{{ handlers.eval_handlers(recording, greet=True) | indent(indent_level + 4, first=True) }}
{% else %}
{{ handlers.twilio_daily_sip_dialin_handlers(recording) | indent(indent_level, first=True) }}
{% endif %}
{% elif 'twilio_daily_sip_dialout' in transports %}
{% if enable_eval %}
{{ handlers.twilio_daily_sip_dialout_handlers(recording) | indent(indent_level + 4, first=True) }}
{{ "else:" | indent(indent_level, first=True) }}
{{ handlers.eval_handlers(recording) | indent(indent_level + 4, first=True) }}
{% else %}
{{ handlers.twilio_daily_sip_dialout_handlers(recording) | indent(indent_level, first=True) }}
{% endif %}
{% else %}
{{ handlers.standard_handlers(recording, bot_type) | indent(indent_level, first=True) }}
{% endif %}

{# Feature-specific event handlers #}
{% if transcription %}
{{ handlers.transcription_handler() | indent(indent_level, first=True) }}
{% endif %}

{% if recording %}
{{ handlers.recording_handler() | indent(indent_level, first=True) }}
{% endif %}

{{ "runner = WorkerRunner(handle_sigint=False)" | indent(indent_level, first=True) }}

{{ "await runner.add_workers(worker)" | indent(indent_level, first=True) }}
{{ "await runner.run()" | indent(indent_level, first=True) }}

