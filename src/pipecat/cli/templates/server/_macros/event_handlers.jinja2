    await worker.cancel()
{% endmacro %}

{# Dial-out call handlers shared by Daily PSTN and Twilio + Daily SIP dial-out #}
{% macro _dialout_call_handlers() %}
@transport.event_handler("on_joined")
async def on_joined(transport, data):
    await dialout_manager.attempt_dialout()

@transport.event_handler("on_dialout_answered")
async def on_dialout_answered(transport, data):
    logger.debug(f"Dial-out answered: {data}")
    dialout_manager.mark_successful()

@transport.event_handler("on_dialout_error")
async def on_dialout_error(transport, data: Any):
    logger.error(f"Dial-out error, retrying: {data}")

    if dialout_manager.should_retry():
        await dialout_manager.attempt_dialout()
    else:
        logger.error("No more retries allowed, stopping bot.")
        await worker.cancel()
{% endmacro %}

{# Daily PSTN dial-out event handlers. With guarded=True the bot also supports
   local runs (webrtc/eval): the dial-out machinery is only set up when the
   request carried dial-out settings, and the bot stays silent otherwise. #}
{% macro daily_pstn_dialout_handlers(guarded=False) %}
{% if guarded %}
if dialout_settings:
    # Production flow: place the outbound call once the bot has joined the room.
    dialout_manager = DialoutManager(transport, dialout_settings)

{{ _dialout_call_handlers() | indent(4, first=True) }}
{% else %}
{{ _dialout_call_handlers() }}
