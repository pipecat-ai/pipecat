# IBM Speech-to-Text Configuration
# Get your credentials from: https://cloud.ibm.com/catalog/services/speech-to-text
IBM_STT_API_KEY=your-stt-api-key-here
IBM_STT_URL=https://api.us-south.speech-to-text.watson.cloud.ibm.com

# IBM Text-to-Speech Configuration
# Get your credentials from: https://cloud.ibm.com/catalog/services/text-to-speech
IBM_TTS_API_KEY=your-tts-api-key-here
IBM_TTS_URL=https://api.us-south.text-to-speech.watson.cloud.ibm.com

# Google Gemini Configuration (for LLM)
GOOGLE_API_KEY=your-google-api-key-here

# Optional: Daily.co configuration (if using Daily transport)
# DAILY_API_KEY=your-daily-api-key-here
# DAILY_ROOM_URL=https://your-domain.daily.co/your-room-name